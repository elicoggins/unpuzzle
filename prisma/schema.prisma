// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  image     String?
  provider  String
  createdAt DateTime  @default(now())
  attempts  Attempt[]
  stats     UserStats?

  @@map("users")
}

model Position {
  id           String    @id @default(cuid())
  fen          String
  sideToMove   String    // "w" or "b"
  bestMove     String    // UCI format
  bestMoveSan  String?   // SAN format for display
  bestMoveEval Int       // centipawns from white's perspective
  topMoves     Json      // Array of { move: string, eval: number, san?: string }
  difficulty   Int       @default(0) // derived from eval spread
  source       String?   // game URL
  opening      String?
  phase        String    @default("middlegame") // opening, middlegame, endgame
  moveNumber   Int       @default(20)
  attempts     Attempt[]

  @@map("positions")
}

model Attempt {
  id             String   @id @default(cuid())
  userId         String
  positionId     String
  playedMove     String   // UCI format
  playedMoveSan  String?  // SAN format
  centipawnLoss  Int
  timeSpentMs    Int
  evalSource     String   @default("precomputed") // "precomputed" or "wasm"
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
  position       Position @relation(fields: [positionId], references: [id])

  @@index([userId])
  @@index([positionId])
  @@index([userId, positionId])
  @@map("attempts")
}

model UserStats {
  userId         String  @id
  totalAttempts  Int     @default(0)
  runningACPL    Float   @default(0)
  bestSessionACPL Float?
  currentStreak  Int     @default(0)
  longestStreak  Int     @default(0)
  user           User    @relation(fields: [userId], references: [id])

  @@map("user_stats")
}
